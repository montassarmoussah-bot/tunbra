rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read/write to messages collection (for contact form)
    match /messages/{messageId} {
      allow create: if request.resource.data.keys().hasAll(['name', 'email', 'interest', 'message', 'timestamp']);
      allow read, update, delete: if false; // Only admin via console
    }
    
    // Allow public writes to visits collection (for tracking)
    match /visits/{visitId} {
      allow create: if true;
      allow read, update, delete: if false;
    }
  }
}
